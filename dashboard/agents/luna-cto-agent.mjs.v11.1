class LunaAgent {
  constructor() {
    this.checkpoint = new CheckpointManager();
    this.analyzer = new IntelligenceAnalyzer();
    this.reporter = new ReportGenerator();
    this.autofix = new AutoFixer();
    this.browser = null;
    this.page = null;
    this.navigator = null;
  }

  async init() {
    logger.info('=== LUNA v11.1 INICIANDO ===');

    // Auto-fix antes de iniciar
    logger.info('Verificando servicios...');
    await this.autofix.verificarServicios();

    try {
      this.browser = await chromium.connectOverCDP(CONFIG.CDP_URL);
      const context = this.browser.contexts()[0];
      this.page = context.pages()[0] || await context.newPage();
      this.navigator = new WhatsAppNavigator(this.page);

      logger.success('Conectado a Chrome CDP');
      return true;
    } catch (e) {
      logger.error(`Fallo conexion: ${e.message}`);
      return false;
    }
  }

  async scanGroup(groupConfig) {
    logger.scan(`Escaneando grupo: ${groupConfig.name}`);

    // Navegação inteligente (NOVO)
    const abierto = await this.navigator.abrirGrupo(groupConfig.name);
    if (!abierto) {
      logger.error(`No se pudo abrir ${groupConfig.name}`);
      return [];
    }

    // Extração com scroll (melhorado)
    const messages = await this.navigator.extraerMensajes(CONFIG.MAX_SCROLLS);

    logger.success(`${messages.length} mensajes extraidos de ${groupConfig.name}`);
    return messages;
  }

  async runOnce() {
    const conectado = await this.init();
    if (!conectado) {
      logger.error('No conectado');
      await this.shutdown();
      return;
    }

    const allMessages = [];

    for (const group of CONFIG.GROUPS) {
      const msgs = await this.scanGroup(group);
      allMessages.push(...msgs.map(m => ({ ...m, group: group.name })));
    }

    // Filtra novas
    const nuevas = allMessages.filter(m => this.checkpoint.isNew(m));
    logger.info(`Filtrado: ${allMessages.length} total, ${nuevas.length} nuevas`);

    if (nuevas.length > 0) {
      // Analisa
      logger.info(`Analizando ${nuevas.length} mensajes...`);
      const analysis = this.analyzer.analyze(nuevas);

      logger.success('Analisis completo!');
      logger.info(`  -> Tareas: ${analysis.tasks.length}`);
      logger.info(`  -> Ideas: ${analysis.ideas.length}`);
      logger.info(`  -> Decisiones: ${analysis.decisions.length}`);
      logger.info(`  -> Links: ${analysis.links.length}`);
      logger.info(`  -> Menciones: ${analysis.mentions.length}`);

      // Marca como processadas
      nuevas.forEach(m => this.checkpoint.markProcessed(m));

      // Gera relatório
      const report = this.reporter.generate({
        messages: nuevas,
        analysis,
        groups: CONFIG.GROUPS
      });

      // Salva
      const timestamp = Date.now();
      fs.writeFileSync(
        path.join(CONFIG.REPORTS_DIR, `report-${timestamp}.html`),
        report.html
      );
      fs.writeFileSync(
        path.join(CONFIG.REPORTS_DIR, `report-${timestamp}.txt`),
        report.txt
      );

      // Atualiza buffer
      this.checkpoint.buffer.newMessages.push(...nuevas);
      this.checkpoint.buffer.newTasks.push(...analysis.tasks);
      this.checkpoint.buffer.newIdeas.push(...analysis.ideas);
      this.checkpoint.buffer.newDecisions.push(...analysis.decisions);
      this.checkpoint.buffer.newLinks.push(...analysis.links);
      this.checkpoint.buffer.newMentions.push(...analysis.mentions);
      this.checkpoint.buffer.lastBufferUpdate = new Date().toISOString();

      logger.success('Reportes generados!');
      this.checkpoint.checkpoint.silenceCount = 0;
    } else {
      this.checkpoint.checkpoint.silenceCount++;
      logger.info(`Sin novedades. Silencio #${this.checkpoint.checkpoint.silenceCount}`);
    }

    // Salva checkpoint
    this.checkpoint.checkpoint.lastScan = new Date().toISOString();
    this.checkpoint.save();

    // Salva dados para dashboard
    this.saveOutput(nuevas);

    logger.success('Ciclo completo finalizado con exito!');
    await this.shutdown();
  }

  saveOutput(messages) {
    const output = {
      messages: messages,
      groups: CONFIG.GROUPS,
      lastUpdated: new Date().toISOString(),
      stats: {
        total: messages.length,
        tasks: messages.filter(m => m.type === 'task').length,
        ideas: messages.filter(m => m.type === 'idea').length,
        decisions: messages.filter(m => m.type === 'decision').length,
        links: messages.filter(m => m.type === 'link').length
      }
    };
    fs.writeFileSync(CONFIG.OUTPUT_FILE, JSON.stringify(output, null, 2));
  }

  async shutdown() {
    if (this.browser) {
      await this.browser.close();
    }
    logger.info('Finalizado');
  }
}

// ============================================================
// EXECUÇÃO
// ============================================================
const agent = new LunaAgent();

// Cria diretórios se não existem
if (!fs.existsSync(CONFIG.REPORTS_DIR)) fs.mkdirSync(CONFIG.REPORTS_DIR, { recursive: true });
if (!fs.existsSync(CONFIG.ARTIFACTS_DIR)) fs.mkdirSync(CONFIG.ARTIFACTS_DIR, { recursive: true });

// Verifica argumentos
const args = process.argv.slice(2);
if (args.includes('--once')) {
  agent.runOnce();
} else {
  logger.info('Modo continuo: scan cada 10 minutos');
  agent.runOnce();
  setInterval(() => agent.runOnce(), CONFIG.SCAN_INTERVAL);
}
