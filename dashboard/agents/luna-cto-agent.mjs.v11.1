// ============================================================
// LOGGER (NOVO - mas mantém estilo original)
// ============================================================
class Logger {
  constructor() {
    this.logFile = path.join(CONFIG.ARTIFACTS_DIR, 'luna-v11.log');
    if (!fs.existsSync(CONFIG.ARTIFACTS_DIR)) {
      fs.mkdirSync(CONFIG.ARTIFACTS_DIR, { recursive: true });
    }
  }

  _hora() {
    return new Date().toISOString();
  }

  _gravar(nivel, msg) {
    const linea = `[${nivel}] [${this._hora()}] ${msg}`;
    console.log(linea);
    fs.appendFileSync(this.logFile, linea + '\n');
  }

  info(msg) { this._gravar('INFO', msg); }
  success(msg) { this._gravar('SUCCESS', msg); }
  error(msg) { this._gravar('ERROR', msg); }
  warn(msg) { this._gravar('WARN', msg); }
  scan(msg) { this._gravar('SCAN', msg); }
}

const logger = new Logger();

// ============================================================
// WHATSAPP NAVIGATOR (NOVO - navegação inteligente)
// ============================================================
class WhatsAppNavigator {
  constructor(page) {
    this.page = page;
    this.estadoActual = null;
    this.ultimoGrupo = null;
    this.intentos = 0;
    this.maxIntentos = 3;
  }

  async detectarEstado() {
    const { SELECTORES, ESTADOS } = UI_MAP;

    const listaVisible = await this.page.isVisible(SELECTORES.listaChats).catch(() => false);
    if (listaVisible) {
      this.estadoActual = ESTADOS.LISTA_CHATS;
      return ESTADOS.LISTA_CHATS;
    }

    const chatVisible = await this.page.isVisible(SELECTORES.chatAbierto).catch(() => false);
    if (chatVisible) {
      this.estadoActual = ESTADOS.CHAT_ABIERTO;
      return ESTADOS.CHAT_ABIERTO;
    }

    const busquedaVisible = await this.page.isVisible(SELECTORES.barraBusqueda).catch(() => false);
    if (busquedaVisible) {
      this.estadoActual = ESTADOS.BUSQUEDA;
      return ESTADOS.BUSQUEDA;
    }

    this.estadoActual = ESTADOS.ERROR;
    return ESTADOS.ERROR;
  }

  async irParaLista() {
    const estado = await this.detectarEstado();

    if (estado === UI_MAP.ESTADOS.LISTA_CHATS) {
      logger.info('NAV: Ya estamos en lista de chats');
      return true;
    }

    if (estado === UI_MAP.ESTADOS.CHAT_ABIERTO) {
      logger.info('NAV: Volviendo a lista...');

      // Método 1: Click en botón atrás
      const btnAtras = await this.page.$(UI_MAP.SELECTORES.btnAtras);
      if (btnAtras) {
        await btnAtras.click();
        await this.page.waitForTimeout(1000);
      }

      // Método 2: Tecla Escape
      await this.page.keyboard.press('Escape');
      await this.page.waitForTimeout(500);

      const nuevoEstado = await this.detectarEstado();
      return nuevoEstado === UI_MAP.ESTADOS.LISTA_CHATS;
    }

    if (estado === UI_MAP.ESTADOS.BUSQUEDA) {
      await this.page.keyboard.press('Escape');
      await this.page.waitForTimeout(500);
      return await this.irParaLista();
    }

    return false;
  }

  async abrirGrupo(nombreGrupo) {
    this.intentos = 0;

    while (this.intentos < this.maxIntentos) {
      this.intentos++;
      logger.scan(`Intento ${this.intentos}/${this.maxIntentos} para abrir: ${nombreGrupo}`);

      // Garante que está na lista
      const enLista = await this.irParaLista();
      if (!enLista) {
        logger.error('NAV: No podemos llegar a la lista');
        return false;
      }

      // MÉTODO 1: Click directo
      const exito1 = await this._clickDirecto(nombreGrupo);
      if (exito1) {
        this.ultimoGrupo = nombreGrupo;
        return true;
      }

      // MÉTODO 2: Búsqueda
      const exito2 = await this._buscarGrupo(nombreGrupo);
      if (exito2) {
        this.ultimoGrupo = nombreGrupo;
        return true;
      }

      // MÉTODO 3: Scroll + click
      const exito3 = await this._scrollYClick(nombreGrupo);
      if (exito3) {
        this.ultimoGrupo = nombreGrupo;
        return true;
      }

      await this.page.waitForTimeout(2000);
    }

    logger.error(`NAV: Fallo total para abrir ${nombreGrupo}`);
    return false;
  }

  async _clickDirecto(nombreGrupo) {
    try {
      // Selector por title
      const selector = `[data-testid="chat-list-item"] [title="${nombreGrupo}"]`;
      const elemento = await this.page.$(selector);

      if (elemento) {
        await elemento.click();
        await this.page.waitForTimeout(1500);

        const estado = await this.detectarEstado();
        if (estado === UI_MAP.ESTADOS.CHAT_ABIERTO) {
          logger.success('NAV: Click directo exitoso!');
          return true;
        }
      }
    } catch (e) {
      logger.warn(`Click directo fallo: ${e.message}`);
    }
    return false;
  }

  async _buscarGrupo(nombreGrupo) {
    try {
      logger.info('NAV: Intentando busqueda...');

      // Abre busqueda con Ctrl+F
      await this.page.keyboard.press('Control+f');
      await this.page.waitForTimeout(500);

      // Escribe nombre
      await this.page.fill(UI_MAP.SELECTORES.inputBusqueda, nombreGrupo);
      await this.page.waitForTimeout(1000);

      // Click en resultado
      const resultado = await this.page.$(UI_MAP.SELECTORES.resultadoBusqueda);
      if (resultado) {
        await resultado.click();
        await this.page.waitForTimeout(1500);

        const estado = await this.detectarEstado();
        if (estado === UI_MAP.ESTADOS.CHAT_ABIERTO) {
          logger.success('NAV: Busqueda exitosa!');
          return true;
        }
      }

      // Limpia busqueda
      await this.page.keyboard.press('Escape');
    } catch (e) {
      logger.warn(`Busqueda fallo: ${e.message}`);
    }
    return false;
  }

  async _scrollYClick(nombreGrupo) {
    try {
      logger.info('NAV: Intentando scroll + click...');

      const container = await this.page.$(UI_MAP.SELECTORES.listaChats);
      if (!container) return false;

      for (let i = 0; i < 5; i++) {
        await container.evaluate(el => el.scrollTop += 500);
        await this.page.waitForTimeout(500);

        const exito = await this._clickDirecto(nombreGrupo);
        if (exito) return true;
      }
    } catch (e) {
      logger.warn(`Scroll fallo: ${e.message}`);
    }
    return false;
  }

  async extraerMensajes(maxScrolls = CONFIG.MAX_SCROLLS) {
    const estado = await this.detectarEstado();
    if (estado !== UI_MAP.ESTADOS.CHAT_ABIERTO) {
      logger.error('EXTRACT: No estamos en chat abierto');
      return [];
    }

    const mensajes = [];
    const vistos = new Set();

    for (let scroll = 0; scroll < maxScrolls; scroll++) {
      logger.scan(`Scroll ${scroll + 1}/${maxScrolls}`);

      const nuevos = await this.page.evaluate((selectores) => {
        const msgs = [];
        document.querySelectorAll(selectores.mensajeEntrada + ', ' + selectores.mensajeSalida).forEach(el => {
          const texto = el.querySelector(selectores.textoMensaje)?.innerText || '';
          const horaEl = el.querySelector('[data-pre-plain-text]');
          const hora = horaEl ? horaEl.getAttribute('data-pre-plain-text') : '';
          const autor = hora.split(']')[1]?.trim() || 'Desconocido';

          if (texto) {
            msgs.push({
              text: texto,
              time: hora,
              author: autor,
              id: texto.slice(0, 50) + hora
            });
          }
        });
        return msgs;
      }, UI_MAP.SELECTORES);

      for (const msg of nuevos) {
        if (!vistos.has(msg.id)) {
          vistos.add(msg.id);
          mensajes.push(msg);
        }
      }

      // Scroll hacia arriba para cargar mas
      await this.page.evaluate(() => {
        const container = document.querySelector('[data-testid="conversation-panel-messages"]');
        if (container) container.scrollTop = 0;
      });

      await this.page.waitForTimeout(1500);
    }

    logger.success(`EXTRACT: ${mensajes.length} mensajes unicos`);
    return mensajes;
  }
}

// ============================================================
// AUTO-FIX (NOVO - mantém agente vivo)
// ============================================================
class AutoFixer {
  async verificarServicios() {
    const servicios = {
      backend: { puerto: 3456, nombre: 'Backend API' },
      frontend: { puerto: 3457, nombre: 'Frontend Vite' },
      chrome: { puerto: 9223, nombre: 'Chrome CDP' }
    };

    const estado = {};

    for (const [clave, config] of Object.entries(servicios)) {
      try {
        const net = await import('net');
        const conectado = await new Promise((resolve) => {
          const socket = net.createConnection(config.puerto, '127.0.0.1');
          socket.on('connect', () => { socket.end(); resolve(true); });
          socket.on('error', () => resolve(false));
          socket.setTimeout(3000, () => { socket.destroy(); resolve(false); });
        });

        estado[clave] = conectado;

        if (!conectado) {
          logger.warn(`AUTO-FIX: ${config.nombre} caido!`);
          await this._reiniciarServicio(clave, config);
        } else {
          logger.info(`AUTO-FIX: ${config.nombre} OK`);
        }
      } catch (e) {
        estado[clave] = false;
        logger.error(`AUTO-FIX: Error verificando ${config.nombre}: ${e.message}`);
      }
    }

    return estado;
  }

  async _reiniciarServicio(clave, config) {
    logger.warn(`AUTO-FIX: Reiniciando ${config.nombre}...`);

    if (clave === 'chrome') {
      // Reinicia Chrome CDP
      const { spawn } = await import('child_process');
      spawn('taskkill', ['/F', '/IM', 'chrome.exe']);

      await new Promise(r => setTimeout(r, 3000));

      spawn('"C:\Program Files\Google\Chrome\Application\chrome.exe"', [
        '--remote-debugging-port=9223',
        '--user-data-dir=C:\Users\Administrator\.luna-chrome-debug',
        '--profile-directory=Luna',
        '--no-first-run',
        '--no-default-browser-check',
        'https://web.whatsapp.com'
      ], { shell: true, detached: true });

      logger.success('AUTO-FIX: Chrome reiniciado');
    }

    // Para backend/frontend, solo loga (no puede reiniciarse a si mismo)
    if (clave === 'backend' || clave === 'frontend') {
      logger.warn(`AUTO-FIX: ${config.nombre} necesita reinicio manual`);
    }
  }
}

// ============================================================
// INTELLIGENCE ANALYZER (mantido do original + melhorias)
// ============================================================
class IntelligenceAnalyzer {
  analyze(messages) {
    return {
      tasks: this.detectTasks(messages),
      ideas: this.detectIdeas(messages),
      decisions: this.detectDecisions(messages),
      links: this.extractLinks(messages),
      mentions: this.detectMentions(messages)
    };
  }

  detectTasks(messages) {
    const patterns = [
      /tarefa|task|todo|fazer|faz|precisa|necessario|urgente|prazo|deadline/i,
      /@kimi|@luna|@abner|@todos|@equipe/i
    ];

    return messages.filter(m => 
      patterns.some(p => p.test(m.text))
    ).map(m => ({
      ...m,
      priority: this._getPriority(m.text),
      type: 'task'
    }));
  }

  _getPriority(text) {
    if (/urgente|critico|p0|imediato|agora/i.test(text)) return 'P0';
    if (/importante|p1|hoje|amanha/i.test(text)) return 'P1';
    if (/normal|rotina|p2|proxima semana/i.test(text)) return 'P2';
    return 'P3';
  }

  detectIdeas(messages) {
    return messages.filter(m => 
      /ideia|sugestao|proposta|que tal|poderiamos|seria bom/i.test(m.text)
    ).map(m => ({ ...m, type: 'idea' }));
  }

  detectDecisions(messages) {
    return messages.filter(m => 
      /decidimos|vamos|ficou acordado|definido|aprovado|confirmado/i.test(m.text)
    ).map(m => ({ ...m, type: 'decision' }));
  }

  extractLinks(messages) {
    const linkRegex = /(https?:\/\/[^\s]+)/g;
    const links = [];

    messages.forEach(m => {
      const found = m.text.match(linkRegex);
      if (found) {
        found.forEach(url => {
          links.push({
            url: url,
            context: m.text.slice(0, 100),
            author: m.author,
            time: m.time
          });
        });
      }
    });

    return [...new Map(links.map(l => [l.url, l])).values()];
  }

  detectMentions(messages) {
    return messages.filter(m => 
      /@kimi|@luna|@abner|@todos|@equipe|@equipo/i.test(m.text)
    ).map(m => ({ ...m, type: 'mention' }));
  }
}

// ============================================================
// CHECKPOINT MANAGER (mantido do original)
// ============================================================
class CheckpointManager {
  constructor() {
    this.checkpoint = this.load();
    this.buffer = this.loadBuffer();
  }

  load() {
    try {
      if (fs.existsSync(CONFIG.CHECKPOINT_FILE)) {
        return JSON.parse(fs.readFileSync(CONFIG.CHECKPOINT_FILE, 'utf8'));
      }
    } catch (e) {
      logger.error(`Checkpoint load error: ${e.message}`);
    }
    return {
      lastScan: null,
      knownMessageHashes: [],
      processedCount: 0,
      silenceCount: 0,
      lastReport: null
    };
  }

  loadBuffer() {
    try {
      if (fs.existsSync(CONFIG.BUFFER_FILE)) {
        return JSON.parse(fs.readFileSync(CONFIG.BUFFER_FILE, 'utf8'));
      }
    } catch (e) {
      logger.error(`Buffer load error: ${e.message}`);
    }
    return {
      newMessages: [],
      newTasks: [],
      newIdeas: [],
      newDecisions: [],
      newLinks: [],
      newMentions: [],
      lastBufferUpdate: null
    };
  }

  save() {
    fs.writeFileSync(CONFIG.CHECKPOINT_FILE, JSON.stringify(this.checkpoint, null, 2));
    fs.writeFileSync(CONFIG.BUFFER_FILE, JSON.stringify(this.buffer, null, 2));
  }

  hashMessage(msg) {
    return `${msg.author}:${msg.text.slice(0, 50)}:${msg.time}`;
  }

  isNew(msg) {
    const hash = this.hashMessage(msg);
    return !this.checkpoint.knownMessageHashes.includes(hash);
  }

  markProcessed(msg) {
    const hash = this.hashMessage(msg);
    this.checkpoint.knownMessageHashes.push(hash);
    this.checkpoint.processedCount++;
  }
}

