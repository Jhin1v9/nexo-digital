# === Node.js / npm ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# === Build / Dist ===
dist/
build/
out/
.next/
.nuxt/
.cache/
*.tsbuildinfo

# === Environment / Secrets ===
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.pem
*.key
*.p12
*.pfx

# === IDE / Editor ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Logs ===
logs/
*.log

# === OS Files ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# === Temporary / Backup ===
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# === Luna-specific ===
.luna-runtime.json
cookies/*.json
kimi-cookies.json
luna-screenshot-*.png
backup-luna-web-*/
*.BAK
*.bak.*

# === Dashboard-specific ===
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3
frontend/.env

# === Test / Coverage ===
coverage/
.nyc_output/
*.lcov

# === Misc ===
*.pid
*.seed
*.pid.lock
.lock-wscript
.node_repl_history
