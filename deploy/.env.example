# ═══════════════════════════════════════════════════════════════════════════
# NEXO DIGITAL — Environment Configuration Template
# Dashboard PRO + Luna Kernel v5.0 Universal Installer
# ═══════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──

# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/database
# Para Neon/Supabase: use a connection string fornecida
# Para local: postgresql://postgres:postgres@localhost:5432/nexo
DATABASE_URL=your_database_url_here

# JWT Secret for authentication (min 64 chars, gere com: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here_min_64_chars

# Telegram Bot Token (get from @BotFather: https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Group Chat ID para notificações
# Para descobrir: adicione o bot ao grupo, mande uma mensagem e execute:
# curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq ".result[-1].message.chat.id"
TELEGRAM_GROUP_CHAT_ID=your_telegram_group_chat_id_here

# Discord Security Webhook URL para alertas críticos
DISCORD_SECURITY_WEBHOOK=your_discord_webhook_url_here

# Internal API Token para comunicação segura entre serviços
# Gere com: openssl rand -hex 32
INTERNAL_API_TOKEN=your_internal_api_token_here

# Public URL do Dashboard (usado em webhooks e notificações)
# Exemplo: https://nexo.duckdns.org ou https://seu-dominio.com
DASHBOARD_PUBLIC_URL=https://your-domain.duckdns.org

# ── EMAIL CONFIGURATION ──

# Opção A: SMTP tradicional (recomendado para testes)
# Para Gmail: gere uma App Password em https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
NEXO_NOTIFICATION_EMAIL=your-email@gmail.com

# Opção B: Gmail OAuth2 (para produção)
# Crie credenciais em: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:3456/auth/gmail/callback

# ── AI / LLM CONFIGURATION ──

# Google Gemini API Key (opcional — para recursos avançados de IA)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── PORTS & NETWORK ──

NODE_ENV=production
DASHBOARD_PORT=3456
LUNA_PORT=3458
VITE_PORT=5173
DB_PORT=5432

# ── CEO / ADMIN CONFIGURATION ──

# Usernames dos CEOs com acesso total (separados por vírgula)
CEO_USERNAMES=abner,nonoke,elias

# ── LUNA KERNEL OPTIONAL ──

# Kimi Bridge Settings
KIMI_TIMEOUT=120000
KIMI_MAX_PAGES=5
KIMI_IDLE_TIMEOUT=600000
KIMI_COOLDOWN_MS=5000
KIMI_MAX_TYPE_LENGTH=500
KIMI_LOG_MAX_MB=10

# Context Auto-Compaction
LUNA_COMPACT_THRESHOLD=24
LUNA_COMPACT_TOKEN_THRESHOLD=120000

# Chrome/Chromium Path (auto-detected if not set)
# LUNA_CHROME_PATH=/usr/bin/google-chrome

# Luna Debug Mode
# LUNA_DEBUG=true
